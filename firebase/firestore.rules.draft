rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    function signedIn() {
      return request.auth != null;
    }

    function isOwner(userId) {
      return signedIn() && request.auth.uid == userId;
    }

    function validApp(appId) {
      return appId == "theunitedstates-site";
    }

    // Deny all by default.
    match /{document=**} {
      allow read, write: if false;
    }

    // App-scoped public content.
    match /apps/{appId}/publicGallery/{docId} {
      allow read: if validApp(appId);
      allow create: if validApp(appId) && signedIn();
      allow update, delete: if false;
    }

    match /apps/{appId}/blogPosts/{postId} {
      allow read: if validApp(appId);
      allow write: if false;
    }

    match /apps/{appId}/seoPages/{pageId} {
      allow read: if validApp(appId);
      allow write: if false;
    }

    // User-owned data.
    match /apps/{appId}/users/{userId} {
      allow read, create, update: if validApp(appId) && isOwner(userId);
      allow delete: if false;
    }

    match /apps/{appId}/projects/{projectId} {
      allow read, create, update: if validApp(appId) && signedIn() && resource.data.userId == request.auth.uid;
      allow delete: if false;
    }

    match /apps/{appId}/generatedSites/{siteId} {
      allow read: if validApp(appId) && (
        resource.data.visibility == "public" ||
        (signedIn() && resource.data.userId == request.auth.uid)
      );
      allow create: if validApp(appId) && signedIn() && request.resource.data.userId == request.auth.uid;
      allow update: if validApp(appId) && signedIn() && resource.data.userId == request.auth.uid;
      allow delete: if false;
    }

    // Leads/contact forms: allow create only with basic validation.
    match /apps/{appId}/leads/{leadId} {
      allow create: if validApp(appId)
        && request.resource.data.keys().hasOnly(["name", "email", "message", "createdAt", "source"])
        && request.resource.data.email is string
        && request.resource.data.message is string
        && request.resource.data.message.size() <= 5000;
      allow read, update, delete: if false;
    }

    match /apps/{appId}/contactSubmissions/{submissionId} {
      allow create: if validApp(appId)
        && request.resource.data.message is string
        && request.resource.data.message.size() <= 5000;
      allow read, update, delete: if false;
    }

    // Settings are readable only if explicitly public.
    match /apps/{appId}/settings/{settingId} {
      allow read: if validApp(appId) && settingId == "public";
      allow write: if false;
    }
  }
}
